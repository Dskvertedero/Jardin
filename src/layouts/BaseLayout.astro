---
import "../styles/global.css";

const { title = "Mi Jardín Digital", description = "Un jardín digital personal, notas en crecimiento.", image } = Astro.props;

const urlActual = Astro.url.href;
---
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={urlActual} />
    {image && <meta property="og:image" content={image} />}
    <meta name="twitter:card" content={image ? "summary_large_image" : "summary"} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300..700&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="site-header">
      <a href="/" class="logo">Vertedero digital </a>
      <nav class="main-nav">
        <a href="/garden">Notas</a>
        <a href="/about">Datos</a>
        <a href="/futuro">Futuro</a>
        <button id="boton-sorpresa" class="boton-sorpresa" type="button">🎲 Sorpréndeme</button>
      </nav>
      <button id="theme-toggle" aria-label="Cambiar tema" class="theme-toggle-btn">
        <span class="icon-light">☀️</span>
        <span class="icon-dark">👻</span>
      </button>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>&copy; 2026 Triple s</p>
    </footer>

    <script is:inline>
      const toggle = document.getElementById("theme-toggle");
      const root = document.documentElement;
      const saved = localStorage.getItem("theme");
      if (saved === "dark") {
        root.setAttribute("data-theme", "dark");
      }
      toggle?.addEventListener("click", () => {
        const isDark = root.getAttribute("data-theme") === "dark";
        if (isDark) {
          root.removeAttribute("data-theme");
          localStorage.setItem("theme", "light");
        } else {
          root.setAttribute("data-theme", "dark");
          localStorage.setItem("theme", "dark");
        }
      });

      const botonSorpresa = document.getElementById("boton-sorpresa");

      botonSorpresa?.addEventListener("click", async () => {
        try {
          const res = await fetch("/notas-ids.json");
          const ids = await res.json();
          if (!ids.length) return;
          const idAleatorio = ids[Math.floor(Math.random() * ids.length)];
          window.location.href = "/" + idAleatorio;
        } catch (error) {
          console.error("Error al obtener nota aleatoria:", error);
        }
      });

      function formatearTiempo(segundos) {
        if (!isFinite(segundos)) return "0:00";
        const m = Math.floor(segundos / 60);
        const s = Math.floor(segundos % 60).toString().padStart(2, "0");
        return `${m}:${s}`;
      }

      document.querySelectorAll(".reproductor-audio, .reproductor-video").forEach((contenedor) => {
        const media = contenedor.querySelector("audio, video");
        const btnPlay = contenedor.querySelector(".rp-play");
        const barra = contenedor.querySelector(".rp-barra");
        const progreso = contenedor.querySelector(".rp-progreso");
        const tiempo = contenedor.querySelector(".rp-tiempo");

        if (!media || !btnPlay || !barra || !progreso) return;

        btnPlay.addEventListener("click", () => {
          if (media.paused) {
            media.play();
            btnPlay.textContent = "⏸";
          } else {
            media.pause();
            btnPlay.textContent = "▶";
          }
        });

        media.addEventListener("timeupdate", () => {
          const pct = (media.currentTime / media.duration) * 100 || 0;
          progreso.style.width = pct + "%";
          if (tiempo) {
            tiempo.textContent = `${formatearTiempo(media.currentTime)} / ${formatearTiempo(media.duration)}`;
          }
        });

        media.addEventListener("ended", () => {
          btnPlay.textContent = "▶";
        });

        barra.addEventListener("click", (e) => {
          const rect = barra.getBoundingClientRect();
          const pct = (e.clientX - rect.left) / rect.width;
          media.currentTime = pct * media.duration;
        });
      });
    </script>
  </body>
</html>
