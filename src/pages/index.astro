---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Grafo from "../components/Grafo.astro";
import { formatearTitulo } from "../lib/titulo";
import { notasPublicadas } from "../lib/draft";

const todasLasNotas = await getCollection("garden");
const notas = notasPublicadas(todasLasNotas);
const recientes = notas.slice(0, 5);
---
<BaseLayout title="Mi Jardín Digital">
  <section class="intro">
    <h1>Holap, es bueno verte por aca </h1>
    <p>
      Es increible las cosas que puede hacer uno cuando anda aburrido, eso y cuando trata de no pensar mucho, ah si supongo que como es una pagina de incio deberia de dar una bienvenida, pues ya que estas acá quedate un rato ¿no?
    </p>
  </section>

  <section class="recent-notes">
    <h2>Notas recientes</h2>
    <ul>
      {recientes.map((nota) => (
        <li>
          <a href={`/${nota.id}`}>{nota.data.title || formatearTitulo(nota.id)}</a>
        </li>
      ))}
    </ul>
    <a href="/garden" class="see-all">Ver todas las notas &rarr;</a>
  </section>

  <Grafo />
</BaseLayout>
