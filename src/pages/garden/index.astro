---
import fs from "node:fs";
import path from "node:path";
import { getCollection } from "astro:content";
import GardenLayout from "../../layouts/GardenLayout.astro";
import { getExcerpt, getContenidoCompleto } from "../../lib/excerpt";
import { agruparPorCategoria } from "../../lib/categorias";
import { notasPublicadas } from "../../lib/draft";
import { formatearTitulo } from "../../lib/titulo";
import Grafo from "../../components/Grafo.astro";

const todasLasNotas = await getCollection("garden");
const notas = notasPublicadas(todasLasNotas);
const grupos = agruparPorCategoria(notas);

function getFechaCreacion(filePath: string) {
  const absolutePath = path.join(process.cwd(), filePath);
  const stats = fs.statSync(absolutePath);
  return stats.birthtime.toLocaleDateString("es-MX", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---
<GardenLayout title="Mi Vertedero Digital">
  <h1>Vertedero Digital</h1>
  <p class="garden-intro">Supongo que un lugarsito mas de internet pero mio.</p>

  <input type="text" id="buscador" class="buscador-input" placeholder="Buscar notas..." />

  <div id="resultados-busqueda" class="resultados-busqueda" style="display: none;">
    <div id="resultados-titulo"></div>
    <div id="resultados-contenido"></div>
    <p id="sin-resultados" style="display: none;">No se encontraron notas.</p>
  </div>

  <div id="vista-categorias">
    {Array.from(grupos.entries()).map(([categoria, notasDeCategoria]) => (
      <section class="categoria-section">
        <h2 class="categoria-titulo">{categoria}</h2>
        <div class="garden-grid">
          {notasDeCategoria.map((nota) => (
            <a href={`/${nota.id}`} class="garden-card" data-titulo={(nota.data.title || path.basename(nota.id)).toLowerCase()} data-contenido={getContenidoCompleto(nota.body)}>
              <h3>{nota.data.title || formatearTitulo(path.basename(nota.id))}</h3>
              <p class="garden-excerpt">{nota.data.descripcion || getExcerpt(nota.body)}</p>
              <span class="garden-date">{getFechaCreacion(nota.filePath)}</span>
            </a>
          ))}
        </div>
      </section>
    ))}
  </div>

  <Grafo />
</GardenLayout>

<script>
  const input = document.getElementById("buscador");
  const vistaCategoria = document.getElementById("vista-categorias");
  const resultadosBusqueda = document.getElementById("resultados-busqueda");
  const resultadosTitulo = document.getElementById("resultados-titulo");
  const resultadosContenido = document.getElementById("resultados-contenido");
  const sinResultados = document.getElementById("sin-resultados");
  const todasLasTarjetas = Array.from(document.querySelectorAll(".garden-card"));

  function crearGrupo(titulo, tarjetas) {
    const seccion = document.createElement("section");
    seccion.classList.add("categoria-section");
    const h2 = document.createElement("h2");
    h2.classList.add("categoria-titulo");
    h2.textContent = titulo;
    seccion.appendChild(h2);
    const grid = document.createElement("div");
    grid.classList.add("garden-grid");
    tarjetas.forEach((t) => grid.appendChild(t.cloneNode(true)));
    seccion.appendChild(grid);
    return seccion;
  }

  input.addEventListener("input", (e) => {
    const query = e.target.value.toLowerCase().trim();
    if (query === "") {
      vistaCategoria.style.display = "";
      resultadosBusqueda.style.display = "none";
      return;
    }
    vistaCategoria.style.display = "none";
    resultadosBusqueda.style.display = "";
    resultadosTitulo.innerHTML = "";
    resultadosContenido.innerHTML = "";
    const coincidenTitulo = [];
    const coincidenContenido = [];
    todasLasTarjetas.forEach((tarjeta) => {
      const titulo = tarjeta.dataset.titulo || "";
      const contenido = tarjeta.dataset.contenido || "";
      if (titulo.includes(query)) {
        coincidenTitulo.push(tarjeta);
      } else if (contenido.includes(query)) {
        coincidenContenido.push(tarjeta);
      }
    });
    if (coincidenTitulo.length > 0) {
      resultadosTitulo.appendChild(crearGrupo("Coincidencias en título", coincidenTitulo));
    }
    if (coincidenContenido.length > 0) {
      resultadosContenido.appendChild(crearGrupo("Coincidencias en contenido", coincidenContenido));
    }
    sinResultados.style.display = coincidenTitulo.length === 0 && coincidenContenido.length === 0 ? "" : "none";
  });
</script>
