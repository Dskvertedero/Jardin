---
import fs from "node:fs";
import path from "node:path";
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const notas = await getCollection("garden");
  return notas.map((nota) => ({
    params: { slug: nota.id },
    props: { nota },
  }));
}

const { nota } = Astro.props;
const { Content } = await render(nota);

const absolutePath = path.join(process.cwd(), nota.filePath);
const stats = fs.statSync(absolutePath);
const fecha = stats.birthtime.toLocaleDateString("es-MX", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---
<BaseLayout title={nota.data.title || nota.id}>
  <a href="/garden">&larr; Volver al jardín</a>
  <h1>{nota.data.title || nota.id}</h1>
  <p class="nota-fecha">{fecha}</p>
  <article class="prose">
    <Content />
  </article>
</BaseLayout>
