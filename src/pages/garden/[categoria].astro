---
import fs from "node:fs";
import path from "node:path";
import { getCollection } from "astro:content";
import GardenLayout from "../../layouts/GardenLayout.astro";
import { getExcerpt, getContenidoCompleto } from "../../lib/excerpt";
import { agruparPorCarpeta, slugifyCategoria } from "../../lib/categorias";
import { notasPublicadas } from "../../lib/draft";

export async function getStaticPaths() {
  const todasLasNotas = await getCollection("garden");
  const notas = notasPublicadas(todasLasNotas);
  const grupos = agruparPorCarpeta(notas);

  return Array.from(grupos.entries()).map(([carpeta, notasDeCarpeta]) => ({
    params: { categoria: slugifyCategoria(carpeta) },
    props: { carpeta, notasDeCarpeta },
  }));
}

const { carpeta, notasDeCarpeta } = Astro.props;

function getFechaCreacion(filePath: string) {
  const absolutePath = path.join(process.cwd(), filePath);
  const stats = fs.statSync(absolutePath);
  return stats.birthtime.toLocaleDateString("es-MX", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---
<GardenLayout title={carpeta} categoriaActiva={carpeta}>
  <h1>{carpeta}</h1>
  <p class="garden-intro">Notas en esta categoría.</p>

  <div class="garden-grid">
    {notasDeCarpeta.map((nota) => (
      <a href={`/${nota.id}`} class="garden-card" data-titulo={(nota.data.title || path.basename(nota.id)).toLowerCase()} data-contenido={getContenidoCompleto(nota.body)}>
        <h3>{nota.data.title || path.basename(nota.id)}</h3>
        <p class="garden-excerpt">{getExcerpt(nota.body)}</p>
        <span class="garden-date">{getFechaCreacion(nota.filePath)}</span>
      </a>
    ))}
  </div>
</GardenLayout>
