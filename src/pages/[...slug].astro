---
import fs from "node:fs";
import path from "node:path";
import { getCollection, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getBacklinksMap } from "../lib/backlinks";
import { notasPublicadas } from "../lib/draft";
import { formatearTitulo } from "../lib/titulo";

export async function getStaticPaths() {
  const todasLasNotas = await getCollection("garden");
  const notas = notasPublicadas(todasLasNotas);
  return notas.map((nota) => ({
    params: { slug: nota.id },
    props: { nota, todasLasNotas: notas },
  }));
}

const { nota, todasLasNotas } = Astro.props;
const { Content } = await render(nota);

const absolutePath = path.join(process.cwd(), nota.filePath);
const stats = fs.statSync(absolutePath);
const fecha = stats.birthtime.toLocaleDateString("es-MX", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const palabras = (nota.body || "").trim().split(/\s+/).length;
const minutosLectura = Math.max(1, Math.ceil(palabras / 200));

const backlinksMap = getBacklinksMap(todasLasNotas);
const backlinkIds = Array.from(backlinksMap.get(nota.id) || []);
const backlinkNotas = todasLasNotas.filter((n) => backlinkIds.includes(n.id));

const tituloNota = nota.data.title || formatearTitulo(path.basename(nota.id));
const portada = nota.data.portada || null;
const urlNota = `https://jardin-zeta.vercel.app/${nota.id}`;

const cuerpo = nota.body || "";
const matchMd = cuerpo.match(/!\[[^\]]*\]\(([^)\s]+)\)/);
const matchHtml = cuerpo.match(/<img[^>]*src=["']([^"']+)["']/);
const imagenRelativa = matchMd?.[1] || matchHtml?.[1] || null;
const imagenOg = imagenRelativa
  ? `https://jardin-zeta.vercel.app${imagenRelativa.startsWith("/") ? "" : "/"}${imagenRelativa}`
  : undefined;
---
<BaseLayout title={tituloNota} description={nota.data.descripcion} image={imagenOg}>
  <a href="/garden">&larr; Volver al jardín</a>
  {portada && <img src={portada} alt={tituloNota} class="nota-portada" />}
  <h1>{tituloNota}</h1>
  <p class="nota-fecha">{fecha} · {minutosLectura} min de lectura</p>
  <article class="prose" id="articulo-nota">
    <Content />
  </article>

  {backlinkNotas.length > 0 && (
    <section class="backlinks">
      <h3>Mencionado en</h3>
      <ul>
        {backlinkNotas.map((n) => (
          <li><a href={`/${n.id}`}>{n.data.title || formatearTitulo(path.basename(n.id))}</a></li>
        ))}
      </ul>
    </section>
  )}

  <section class="comentarios">
    <h3>Comentarios</h3>
    <p class="nota-moderacion">Tu comentario quedará pendiente de revisión antes de aparecer públicamente.</p>
    <div
      id="cusdis_thread"
      data-host="https://cusdis.com"
      data-app-id="183e20bf-2c00-483a-915d-b403e6c34176"
      data-page-id={nota.id}
      data-page-url={urlNota}
      data-page-title={tituloNota}
    ></div>
    <script>
      document.getElementById("cusdis_thread")?.setAttribute(
        "data-theme",
        document.documentElement.getAttribute("data-theme") === "dark" ? "dark" : "light"
      );
    </script>
    <script async defer src="https://cusdis.com/js/cusdis.es.js"></script>
  </section>

  <div id="barra-progreso-lectura"><div id="barra-progreso-relleno"></div></div>
</BaseLayout>

<script>
  const contenido = document.querySelector(".prose");
  if (contenido) {
    let nodo = contenido.firstElementChild;
    while (nodo) {
      const texto = (nodo.textContent || "").trim();
      const vacio = texto.length === 0;
      const esPropiedades = texto.includes("Properties");
      const esLatex = texto.startsWith("\\") ||
                      texto.includes("\\newcommand") ||
                      texto.includes("\\def") ||
                      texto.includes("\\DeclareMathOperator") ||
                      /^\$\$[\s\S]*?\$\$$/.test(texto) ||
                      (nodo.tagName === "P" && /^\\\w+/.test(texto));
      if (!vacio && !esPropiedades && !esLatex) break;
      const siguiente = nodo.nextElementSibling;
      nodo.remove();
      nodo = siguiente;
    }
  }

  const articulo = document.getElementById("articulo-nota");
  const relleno = document.getElementById("barra-progreso-relleno");

  function actualizarProgreso() {
    if (!articulo || !relleno) return;
    const inicio = articulo.offsetTop;
    const alto = articulo.offsetHeight;
    const avance = window.scrollY - inicio + window.innerHeight * 0.5;
    const pct = Math.min(100, Math.max(0, (avance / alto) * 100));
    relleno.style.width = pct + "%";
  }

  window.addEventListener("scroll", actualizarProgreso);
  actualizarProgreso();
</script>
